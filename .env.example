# NBA API 配置
NBA_API_PROVIDER=balldontlie  # balldontlie | nba | mysportsfeeds
NBA_API_KEY=

# 数据存储配置
ENABLE_MONGODB=false
MONGO_URI=mongodb://127.0.0.1:27017/
DB_NAME=nba_stats
COLLECTION_NAME=games

# 飞书多维表格配置
ENABLE_FEISHU=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_SPREADSHEET_TOKEN=
FEISHU_TABLE_ID=

# 爬取配置
SEASON=2025
MAX_PAGES=10

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/nba.log

# 数据导出配置
ENABLE_CSV=true
ENABLE_JSON=false
ENABLE_EXCEL=false

# 定时任务配置
ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_HOURS=2
